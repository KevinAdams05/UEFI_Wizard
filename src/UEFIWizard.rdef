resource app_signature "application/x-vnd.UEFIWizard";

resource app_flags B_SINGLE_LAUNCH;

resource app_version {
	major  = 0,
	middle = 1,
	minor  = 0,

	variety = B_APPV_BETA,
	internal = 0,

	short_info = "UEFI Wizard",
	long_info = "Finishes the EFI half of a Haiku install: ESP create + loader copy."
};

resource(1, "BEOS:FILE_TYPES") message {
	"types" = "application/x-vnd.UEFIWizard"
};

